FROM stagex/pallet-gcc-gnu-busybox AS build
ARG VERSION

ADD fetch/${VERSION}.tar.gz .
WORKDIR /hardened_malloc-${VERSION}

RUN --network=none <<-EOF
	set -eux
	make CONFIG_NATIVE=false CC=gcc -j "$(nproc)"
	mkdir -p /rootfs/usr/lib
	install -m755 out/libhardened_malloc.so /rootfs/usr/lib/
	install -vDm644 -t "/rootfs/usr/share/licenses/hardened_malloc" LICENSE
EOF

FROM stagex/core-filesystem AS package
COPY --from=build /rootfs/ /
