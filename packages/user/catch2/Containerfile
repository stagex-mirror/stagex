FROM stagex/pallet-clang-cmake-busybox AS build
ARG VERSION
COPY --from=stagex/user-ninja . /
ADD fetch/v3.5.3.tar.gz .
WORKDIR /Catch2-3.5.3
RUN --network=none <<-EOF
    set -e
    mkdir -p build
    cmake -B build -GNinja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib -DCATCH_BUILD_TESTS=OFF -DCATCH_BUILD_EXAMPLES=OFF -DCATCH_BUILD_EXTRA_FILES=OFF .
    cmake --build build
    DESTDIR=/rootfs cmake --install build
EOF
FROM stagex/core-filesystem AS package
COPY --from=build /rootfs/ /
