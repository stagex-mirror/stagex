FROM stagex/pallet-gcc-cmake-busybox AS build
ARG VERSION
COPY --from=stagex/user-ninja . /
COPY --from=stagex/core-make . /
COPY --from=stagex/core-gcc . /
COPY --from=stagex/core-patchelf . /
COPY --from=stagex/core-python . /
COPY --from=stagex/user-protobuf . /
COPY --from=stagex/user-eigen . /
COPY --from=stagex/user-fftw3 . /
COPY --from=stagex/user-flatbuffers . /
COPY --from=stagex/user-yaml-cpp . /
COPY --from=stagex/user-spdlog . /
COPY --from=stagex/user-msgpack-cxx . /
COPY --from=stagex/user-libdivide . /
COPY --from=stagex/user-simde . /
COPY --from=stagex/user-functionalplus . /
COPY --from=stagex/user-catch2 . /
COPY --from=stagex/user-googletest . /
COPY --from=stagex/user-numactl . /
COPY --from=stagex/user-elfutils . /
COPY --from=stagex/user-libdrm . /
COPY --from=stagex/core-boost . /
COPY --from=stagex/core-libzstd . /
COPY --from=stagex/core-openssl . /
COPY --from=stagex/core-zlib . /
COPY fetch/rocm-cmake.tar.gz /src/
COPY fetch/half.tar.gz /src/
COPY fetch/hipify.tar.gz /src/
COPY fetch/llvm-project.tar.gz /src/
COPY fetch/rocm-libraries.tar.gz /src/
COPY fetch/rocm-systems.tar.gz /src/
COPY fetch/spirv-llvm-translator.tar.gz /src/
COPY fetch/mesa-fork.tar.gz /src/
COPY fetch/iree.tar.gz /src/
COPY fetch/fusilli.tar.gz /src/
COPY fetch/libhipcxx.tar.gz /src/
COPY fetch/rocgdb.tar.gz /src/
COPY fetch/therock.tar.gz /src/
WORKDIR /src
RUN --network=none <<-EOF
    set -e
    
    # Extract rocm-cmake first
    tar -xzf ./rocm-cmake.tar.gz
    
    # Create a fake git command that always succeeds (to prevent TheRock from trying to use git)
    mkdir -p /tmp/fake-bin
    cat > /tmp/fake-bin/git << 'GITEOF'
#!/bin/sh
# Fake git command for TheRock submodules - always succeeds
exit 0
GITEOF
    chmod +x /tmp/fake-bin/git
    export PATH="/tmp/fake-bin:$PATH"
    
    # Install rocm-cmake first
    mkdir -p /rootfs/usr
    cmake -B rocm-cmake-build -GNinja \
        -DCMAKE_BUILD_TYPE=None \
        -DCMAKE_INSTALL_PREFIX=/usr \
        ./rocm-cmake-master
    cmake --build rocm-cmake-build
    DESTDIR=/rootfs cmake --install rocm-cmake-build
    
    # Extract main TheRock source
    tar -xzf ./therock.tar.gz -C / TheRock-main/
    
    # Extract submodules to /tmp first, then move to expected paths
    # half -> base/half
    tar -xzf ./half.tar.gz -C /tmp/
    mv /tmp/half-rocm /TheRock-main/base/half
    
    # HIPIFY -> compiler/hipify
    tar -xzf ./hipify.tar.gz -C /tmp/
    mv /tmp/HIPIFY-amd-mainline /TheRock-main/compiler/hipify
    
    # llvm-project -> compiler/amd-llvm/llvm
    tar -xzf ./llvm-project.tar.gz -C /tmp/
    mv /tmp/llvm-project-amd-mainline /TheRock-main/compiler/amd-llvm/llvm
    
    # rocm-libraries -> rocm-libraries
    tar -xzf ./rocm-libraries.tar.gz -C /tmp/
    mv /tmp/rocm-libraries-develop /TheRock-main/rocm-libraries
    
    # rocm-systems -> rocm-systems
    tar -xzf ./rocm-systems.tar.gz -C /tmp/
    mv /tmp/rocm-systems-develop /TheRock-main/rocm-systems
    
    # SPIRV-LLVM-Translator -> compiler/spirv-llvm-translator
    tar -xzf ./spirv-llvm-translator.tar.gz -C /tmp/
    mv /tmp/SPIRV-LLVM-Translator-amd-mainline /TheRock-main/compiler/spirv-llvm-translator
    
    # mesa-fork -> third-party/sysdeps/linux/amd-mesa/mesa-fork
    tar -xzf ./mesa-fork.tar.gz -C /tmp/
    mv /tmp/mesa-fork-amd-decode-only /TheRock-main/third-party/sysdeps/linux/amd-mesa/mesa-fork
    
    # iree -> iree-libs/iree
    tar -xzf ./iree.tar.gz -C /tmp/
    mv /tmp/iree-main /TheRock-main/iree-libs/iree
    
    # fusilli -> iree-libs/fusilli
    tar -xzf ./fusilli.tar.gz -C /tmp/
    mv /tmp/fusilli-main /TheRock-main/iree-libs/fusilli
    
    # libhipcxx -> math-libs/libhipcxx
    tar -xzf ./libhipcxx.tar.gz -C /tmp/
    mv /tmp/libhipcxx-amd-develop /TheRock-main/math-libs/libhipcxx
    
    # rocgdb -> debug-tools/rocgdb/source
    tar -xzf ./rocgdb.tar.gz -C /tmp/
    mv /tmp/ROCgdb-amd-staging-rocgdb-16 /TheRock-main/debug-tools/rocgdb/source
    
    # Build TheRock - will build all ROCm components
    mkdir -p /TheRock-main/build
    cmake -B /TheRock-main/build -GNinja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DPython3_EXECUTABLE=/usr/bin/python3 \
        -DTHEROCK_BUILD_SHARED_LIBS=ON \
        -DTHEROCK_BUNDLE_SYSDEPS=OFF \
        -DTHEROCK_ENABLE_TESTS=OFF \
        -DTHEROCK_ENABLE_ROCGDB=OFF \
        -DTHEROCK_ENABLE_LIBHIPCXX=OFF \
        -DTHEROCK_AMDGPU_FAMILIES=gfx1100 \
        /TheRock-main
    cmake --build /TheRock-main/build -j "$(nproc)"
    DESTDIR=/rootfs cmake --install /TheRock-main/build
EOF
FROM stagex/core-filesystem AS package
COPY --from=build /rootfs/ /
