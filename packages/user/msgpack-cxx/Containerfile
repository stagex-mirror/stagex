FROM stagex/pallet-clang-cmake-busybox AS build
ARG VERSION
COPY --from=stagex/user-ninja . /
ADD fetch/msgpack-cxx-6.1.0.tar.gz .
WORKDIR /msgpack-c-cpp-6.1.0
RUN --network=none <<-EOF
    set -e
    mkdir -p build
    cmake -B build -GNinja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DMSGPACK_BUILD_TESTS=OFF -DMSGPACK_BUILD_EXAMPLES=OFF -DMSGPACK_USE_BOOST=OFF .
    cmake --build build
    DESTDIR=/rootfs cmake --install build
EOF
FROM stagex/core-filesystem AS package
COPY --from=build /rootfs/ /
