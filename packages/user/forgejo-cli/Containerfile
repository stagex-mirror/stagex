FROM stagex/pallet-rust AS build
ARG VERSION
ADD fetch/forgejo-cli-${VERSION}.tar.gz .
WORKDIR /forgejo-cli-${VERSION}
ENV RUST_BACKTRACE=1
ENV RUSTFLAGS='-C codegen-units=1 -C target-feature=+crt-static'
RUN cargo fetch
RUN --network=none <<-EOF
	cargo build \
		--frozen \
		--release \
		--target $(uname -m)-unknown-linux-musl \
		--bin fj
	mkdir -p /rootfs/usr/bin
	cp target/$(uname -m)-unknown-linux-musl/release/fj /rootfs/usr/bin/
	install -Dm644 -t /rootfs/usr/share/licenses/forgejo-cli LICENSE-MIT
EOF

FROM stagex/core-filesystem AS package
COPY --from=build /rootfs/ /
