FROM stagex/pallet-clang-cmake-busybox AS build
ARG VERSION
COPY --from=stagex/user-ninja . /
ADD fetch/v24.3.25.tar.gz .
WORKDIR /flatbuffers-24.3.25
RUN --network=none <<-EOF
    set -e
    mkdir -p build
    cmake -B build -GNinja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib -DFLATBUFFERS_BUILD_TESTS=OFF .
    cmake --build build
    DESTDIR=/rootfs cmake --install build
EOF
FROM stagex/core-filesystem AS package
COPY --from=build /rootfs/ /
